{
  "name": "dsl-runner-idea",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "prisma generate && next build && tsc -p tsconfig.server.json",
    "start": "prisma generate && prisma db push && node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "db:push": "prisma db push",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@langchain/langgraph": "latest",
    "@langchain/openai": "latest",
    "@monaco-editor/react": "latest",
    "@openrouter/ai-sdk-provider": "latest",
    "@prisma/client": "latest",
    "@tanstack/react-query": "latest",
    "ai": "latest",
    "bullmq": "latest",
    "cheerio": "latest",
    "express": "latest",
    "ioredis": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "prisma": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
