generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Workflow {
  id         String        @id @default(cuid())
  workflowId String        @unique
  name       String
  dsl        String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  runs       WorkflowRun[]
}

model WorkflowRun {
  id             String         @id @default(cuid())
  workflowId      String
  status         String
  formData       Json
  contextData    Json
  errorMessage   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  completedAt    DateTime?
  workflow       Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps          WorkflowStep[]
}

model WorkflowStep {
  id             String   @id @default(cuid())
  runId         String
  stepId       String
  stepType     String
  status       String
  orderIndex   Int
  inputData    Json
  outputData   Json
  renderedPrompt String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  run          WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Prompt {
  id        String   @id @default(cuid())
  promptId  String   @unique
  name      String   @default("")
  template  String
  version   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
