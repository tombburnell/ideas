{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": ".",
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "incremental": false
  },
  "include": ["src/server/**/*.ts", "src/shared/**/*.ts", "src/config/**/*.ts", "src/generated/**/*.ts"],
  "exclude": ["node_modules", "src/app", "src/components", "src/contexts", "src/hooks", "src/lib"]
}
