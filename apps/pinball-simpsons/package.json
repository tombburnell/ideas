{
  "name": "pinball-simpsons",
  "version": "1.0.0",
  "private": true,
  "description": "Simpsons pinball idea app",
  "type": "module",
  "scripts": {
    "build:server": "tsc",
    "build:client": "node ./scripts/build-client.mjs",
    "build": "npm-run-all build:client build:server",
    "dev:client": "node ./scripts/build-client.mjs --watch",
    "dev:server": "tsx watch src/server.ts",
    "dev": "npm-run-all --parallel dev:client dev:server",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dimforge/rapier2d-compat": "^0.19.3",
    "@libsql/client": "^0.17.2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pixi.js": "^8.17.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
