# Copy to .env for local development
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://yellowsub:yellowsub@localhost:5433/yellowsub
REDIS_URL=redis://localhost:6380
CREDENTIALS_ENCRYPTION_KEY=
# 32-byte key as hex (64 chars), e.g. openssl rand -hex 32
PUBLIC_BASE_URL=http://localhost:4000

# Firebase Admin (service account JSON path or inline JSON via FIREBASE_SERVICE_ACCOUNT_JSON)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Comma-separated admin emails allowed to access admin API (in addition to AdminScope in DB)
ADMIN_EMAIL_ALLOWLIST=

# Optional: disable Bull workers in dev
DISABLE_WORKERS=false
